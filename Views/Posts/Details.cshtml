@using System.Security.Claims
@model ASP_MessageBoard.Services.DTOs.PostDetails

@{
    ViewData["Title"] = "文章內容";

    var currentUserIdText =
        User.FindFirstValue(ClaimTypes.NameIdentifier);

    var isAuthor =
        int.TryParse(currentUserIdText, out var currentUserId)
        && currentUserId == Model.UserId;
}

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success" role="alert">
        @message
    </div>
}
<article class="card shadow-sm">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between
            align-items-start gap-3 mb-3">
            <div>
                <h1 class="h4 mb-1">@Model.UserName</h1>

                <div class="text-muted">
                    發表於
                    @Model.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")

                    @if (Model.UpdatedAt.HasValue)
                    {
                        <span class="ms-2">
                            更新於
                            @Model.UpdatedAt.Value.ToLocalTime().ToString("yyyy/MM/dd HH:mm")
                        </span>
                    }
                </div>
            </div>

            @if (isAuthor)
            {
                <div class="d-flex gap-2">
                    <a asp-controller="Posts"
                       asp-action="Edit"
                       asp-route-id="@Model.PostId"
                       class="btn btn-outline-secondary">
                        編輯
                    </a>

                    <form asp-controller="Posts"
                          asp-action="Delete"
                          asp-route-id="@Model.PostId"
                          method="post"
                          onsubmit="return confirm('確定要刪除這篇文章嗎？');">
                        <button type="submit"
                                class="btn btn-outline-danger">
                            刪除
                        </button>
                    </form>
                </div>
            }
        </div>

        <p style="white-space: pre-wrap;">@Model.Content</p>

        @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
        {
            <img src="@Model.ImagePath"
                 class="img-fluid rounded"
                 alt="文章圖片" />
        }
    </div>
</article>

<div class="mt-3">
    <a asp-controller="Posts"
       asp-action="Index"
       class="btn btn-link">
        返回文章列表
    </a>
</div>