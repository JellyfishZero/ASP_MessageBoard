@model ASP_MessageBoard.ViewModels.EditPostViewModel

@{
    ViewData["Title"] = "編輯文章";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-4">編輯文章</h1>

                <form asp-controller="Posts"
                      asp-action="Edit"
                      asp-route-id="@Model.PostId"
                      method="post"
                      enctype="multipart/form-data">
                    <input asp-for="PostId" type="hidden" />

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Content"
                               class="form-label"></label>

                        <textarea asp-for="Content"
                                  class="form-control"
                                  rows="8"
                                  maxlength="2000"></textarea>

                        <div class="form-text">
                            最多 2000 個字元
                        </div>

                        <span asp-validation-for="Content"
                              class="text-danger"></span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.ExistingImagePath))
                    {
                        <div class="mb-3">
                            <div class="form-label">目前圖片</div>

                            <img src="@Model.ExistingImagePath"
                                 class="img-fluid rounded mb-2"
                                 style="max-height: 400px;"
                                 alt="目前文章圖片" />

                            <div class="form-check">
                                <input asp-for="RemoveImage"
                                       class="form-check-input" />

                                <label asp-for="RemoveImage"
                                       class="form-check-label"></label>
                            </div>
                        </div>
                    }

                    <div class="mb-4">
                        <label asp-for="Image"
                               class="form-label"></label>

                        <input asp-for="Image"
                               class="form-control"
                               accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />

                        <div class="form-text">
                            選擇新圖片會取代目前圖片。支援 JPG、PNG、WebP，最大 5 MB。
                        </div>

                        <span asp-validation-for="Image"
                              class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary">
                            儲存變更
                        </button>

                        <a asp-controller="Posts"
                           asp-action="Details"
                           asp-route-id="@Model.PostId"
                           class="btn btn-outline-secondary">
                            取消
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}