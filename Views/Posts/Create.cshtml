@model ASP_MessageBoard.ViewModels.CreatePostViewModel

@{
    ViewData["Title"] = "發表文章";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-4">發表文章</h1>

                <form asp-controller="Posts"
                      asp-action="Create"
                      method="post"
                      enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Content"
                               class="form-label"></label>

                        <textarea asp-for="Content"
                                  class="form-control"
                                  rows="8"
                                  maxlength="2000"
                                  placeholder="分享一些內容……"></textarea>

                        <div class="form-text">
                            最多 2000 個字元
                        </div>

                        <span asp-validation-for="Content"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Image"
                               class="form-label"></label>

                        <input asp-for="Image"
                               class="form-control"
                               accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />

                        <div class="form-text">
                            選填。支援 JPG、PNG、WebP，最大 5 MB。
                        </div>

                        <span asp-validation-for="Image"
                              class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary">
                            發表
                        </button>

                        <a asp-controller="Posts"
                           asp-action="Index"
                           class="btn btn-outline-secondary">
                            取消
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}