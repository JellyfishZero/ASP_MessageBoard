@model IReadOnlyList<ASP_MessageBoard.Services.DTOs.PostDetails>

@using System.Security.Claims

@{
    ViewData["Title"] = "文章列表";

    var currentUserIdText =
        User.FindFirstValue(ClaimTypes.NameIdentifier);

    var hasCurrentUserId =
        int.TryParse(currentUserIdText, out var currentUserId);
}

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success" role="alert">
        @message
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">文章列表</h1>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Posts"
           asp-action="Create"
           class="btn btn-primary">
            發表文章
        </a>
    }
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info" role="alert">
        目前還沒有文章。
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var post in Model)
        {
            var isAuthor =
                hasCurrentUserId && currentUserId == post.UserId;

            <div class="col-12">
                <article class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between
                            align-items-start gap-3 mb-3">
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrWhiteSpace(post.UserCoverImagePath))
                                {
                                    <img src="@post.UserCoverImagePath"
                                         class="user-avatar rounded-circle"
                                         alt="@post.UserName 的個人照片"
                                         loading="lazy" />
                                }
                                else
                                {
                                    <div class="user-avatar user-avatar-placeholder rounded-circle
                                                d-flex align-items-center justify-content-center"
                                         aria-label="@post.UserName 沒有設定個人照片">
                                        @(string.IsNullOrWhiteSpace(post.UserName)
                                            ? "?"
                                            : post.UserName[..1])
                                    </div>
                                }

                                <div>
                                    <h2 class="h5 mb-1">
                                        @post.UserName
                                    </h2>

                                    <small class="text-muted">
                                        @post.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")
                                    </small>

                                    @if (post.UpdatedAt.HasValue)
                                    {
                                        <small class="text-muted ms-2">
                                            已編輯
                                        </small>
                                    }
                                </div>
                            </div>
                        </div>

                        <p class="card-text"
                           style="white-space: pre-wrap;">@post.Content</p>

                        @if (!string.IsNullOrWhiteSpace(post.ImagePath))
                        {
                            <img src="@post.ImagePath"
                                 class="img-fluid rounded d-block mb-3"
                                 alt="文章圖片"
                                 loading="lazy" />
                        }

                        <div class="d-flex flex-wrap gap-2">
                            <a asp-controller="Posts"
                               asp-action="Details"
                               asp-route-id="@post.PostId"
                               class="btn btn-outline-primary">
                                查看文章
                            </a>

                            @if (isAuthor)
                            {
                                <a asp-controller="Posts"
                                   asp-action="Edit"
                                   asp-route-id="@post.PostId"
                                   class="btn btn-outline-secondary">
                                    編輯
                                </a>

                                <form asp-controller="Posts"
                                      asp-action="Delete"
                                      asp-route-id="@post.PostId"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('確定要刪除這篇文章嗎？');">
                                    <button type="submit"
                                            class="btn btn-outline-danger">
                                        刪除
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
}
